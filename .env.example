# Base de donnees MySQL
DB_TYPE=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=futureKawa
DB_USER=root
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# Broker MQTT
MQTT_BROKER=mosquitto

# Flask
FLASK_DEBUG=False
PORT=5000
HOST=0.0.0.0
SECRET_KEY=remplacer-par-une-cle-aleatoire

# Logging
DB_ECHO=False

# Mailjet — recuperer sur https://app.mailjet.com/account/apikeys
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
MJ_EMAIL_SENDER=noreply@example.com
MJ_EMAIL_SENDER_NAME=FutureKawa Alertes